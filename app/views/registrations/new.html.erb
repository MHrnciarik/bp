<div class="mx-auto max-w-md px-4 py-12">
  <div class="card w-full max-w-md bg-base-100 shadow-xl">
    <div class="card-body">
      <h1 class="text-3xl font-bold text-center">Sign up</h1>

      <% if @user.errors.any? %>
        <div class="alert alert-error">
          <ul class="list-disc pl-5">
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with model: @user, url: sign_up_path, class: "space-y-4" do |f| %>
        <div>
          <%= f.label :username, class: "label font-semibold" %>
          <%= f.text_field :username, class: "input input-bordered w-full" %>
        </div>

        <div>
          <%= f.label :password, class: "label font-semibold" %>
          <%= f.password_field :password, class: "input input-bordered w-full" %>
        </div>

        <div>
          <%= f.label :password_confirmation, "Confirm password", class: "label font-semibold" %>
          <%= f.password_field :password_confirmation, class: "input input-bordered w-full" %>
        </div>

        <%= f.submit "Create account", class: "btn btn-primary w-full" %>
      <% end %>

      <p class="text-center text-sm">
        Already have an account?
        <%= link_to "Log in", login_path, class: "link link-primary" %>
      </p>
    </div>
  </div>
</div>

<div class="flex flex-col items-center">
  <div class="w-full max-w-5xl">
    <% if @vendors.any? %>
      <div class="flex justify-center my-4">
        <div class="overflow-x-auto rounded-box border-3 border-base-content/10 w-full">
          <table class="table-lg table-fixed w-full">
            <thead>
              <tr class="border-b-2 border-base-content/10 text-left">
                <th>Meno</th>
                <th>Adresa</th>
                <th>Poznámka</th>
              </tr>
            </thead>
            <tbody>
              <% @vendors.each do |vendor| %>
                <tr class="hover:bg-base-300 border-b border-base-content/5 cursor-pointer" onclick="window.location='<%= vendor_path(vendor) %>'">
                  <td><%= vendor.name %></td>
                  <td><%= vendor.address.presence || "—" %></td>
                  <td><%= truncate(vendor.note, length: 80).presence || "—" %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% else %>
      <p class="my-4">Nenašli sa žiadni predajcovia.</p>
    <% end %>
  </div>
</div>

<div class="fab m-4">
  <%= link_to "+", new_vendor_path, class: "btn btn-lg btn-circle btn-primary" %>
</div>

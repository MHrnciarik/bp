<div class="mx-auto max-w-md px-4 py-12">
  <div class="card bg-base-100 shadow-xl">
    <div class="card-body">
      <h1 class="text-3xl font-bold text-center">Prihlásenie</h1>

      <%= form_with url: login_path, class: "space-y-4" do |f| %>
        <div>
          <%= f.label :username, "Používateľské meno", class: "label font-semibold" %>
          <%= f.text_field :username, class: "input input-bordered w-full" %>
        </div>

        <div>
          <%= f.label :password, "Heslo", class: "label font-semibold" %>
          <%= f.password_field :password, class: "input input-bordered w-full" %>
        </div>

        <%= f.submit "Prihlásiť sa", class: "btn btn-primary w-full" %>
      <% end %>

      <p class="text-center text-sm">
        Ešte nemáš účet?
        <%= link_to "Zaregistruj sa", sign_up_path, class: "link link-primary" %>
      </p>
    </div>
  </div>
</div>

<div class="mx-auto w-full max-w-6xl px-4 pb-16">
  <div class="mb-6 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
    <div>
      <h1 class="text-3xl font-bold">Moje odznaky</h1>
    </div>

    <%= link_to "Späť na profil", profiles_path, class: "btn btn-outline" %>
  </div>

  <section class="mb-6 rounded-box border-3 border-base-content/10 bg-base-100/30 p-5">
    <div class="mb-5 flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
      <div>
        <h2 class="text-xl font-bold">Odmeny za odznaky</h2>
        <p class="text-sm text-base-content/60">
          Získané odznaky: <%= @earned_achievement_count %>
        </p>
      </div>
    </div>

    <div class="relative px-3 py-4">
      <div class="absolute left-8 right-8 top-12 h-1 rounded-full bg-base-content/15"></div>

      <div class="relative grid grid-cols-4 gap-3">
        <% User::ACHIEVEMENT_COUNT_REWARDS.each do |target, xp| %>
          <% claimed = current_user.achievement_count_reward_claimed?(target) %>
          <div class="flex flex-col items-center gap-2 text-center">
            <div class="flex h-14 w-14 items-center justify-center rounded-full border-3 font-bold <%= claimed ? "border-success bg-success text-success-content" : "border-base-content/25 bg-base-100 text-base-content/70" %>">
              <%= claimed ? "✓" : target %>
            </div>
            <div>
              <p class="text-sm font-semibold"><%= target %> odznakov</p>
              <p class="text-xs text-base-content/60"><%= xp %> XP</p>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </section>

  <div class="space-y-6">
    <% @achievement_groups.each do |group, achievements| %>
      <section class="rounded-box border-3 border-base-content/10 bg-base-100/30 p-5">
        <div class="mb-4 flex items-center justify-between gap-4">
          <h2 class="text-xl font-bold"><%= AchievementCatalog::GROUPS.fetch(group) %></h2>
          <span class="badge badge-primary badge-outline">
            <%= @stats.fetch(achievements.first[:metric]) %>
          </span>
        </div>

        <div class="grid grid-cols-2 gap-4 md:grid-cols-4">
          <% achievements.each do |achievement| %>
            <% earned = @earned_by_key[achievement[:key]] %>
            <div class="rounded-box border border-base-content/10 bg-base-100/40 p-4 <%= earned ? "ring-2 ring-primary/40" : "opacity-55" %>">
              <div class="mx-auto flex h-20 w-20 items-center justify-center rounded-full border-3 <%= earned ? "border-primary bg-primary/10 text-primary" : "border-base-content/20 bg-base-200/40 text-base-content/50" %>">
                <span class="text-2xl font-bold"><%= achievement[:target] %></span>
              </div>

              <div class="mt-3 text-center">
                <h3 class="font-semibold"><%= achievement[:title] %></h3>
                <p class="mt-1 text-sm text-base-content/60">
                  <% if earned %>
                    Získané <%= l(earned.awarded_at.to_date, format: :short) %>
                  <% else %>
                    Ešte nezískané
                  <% end %>
                </p>
              </div>
            </div>
          <% end %>
        </div>
      </section>
    <% end %>
  </div>
</div>

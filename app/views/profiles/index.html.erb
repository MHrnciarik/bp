<div class="mx-auto mt-5 w-full max-w-xl px-4 py-16">
  <% if logged_in? %>
    <div class="card border border-base-content/10 bg-base-100 shadow-xl">
      <div class="card-body space-y-6">
        <div class="text-center space-y-4">
          <h1 class="text-3xl font-bold">Profile</h1>
          <h2 class="font-bold"><%= current_user.username %></h2>


          <div class="flex justify-center gap-3">
            <%= link_to "Add company", new_company_path, class: "btn btn-primary" %>
            <%= button_to "Log out", logout_path, method: :delete, class: "btn btn-error" %>
          </div>
        </div>

        <div>
          <h2 class="text-xl font-bold mb-4">Your companies</h2>

          <% if current_user.companies.any? %>
            <div class="space-y-4">
              <% current_user.companies.each do |company| %>
                <div class="rounded-box border border-base-content/10 p-4">
                  <h3 class="text-lg font-semibold"><%= company.name %></h3>

                  <div class="mt-2 space-y-1 text-sm text-base-content/70">
                    <p><strong>ICO:</strong> <%= company.ico %></p>
                    <p><strong>DIC:</strong> <%= company.dic.presence || "—" %></p>
                    <p><strong>IC DPH:</strong> <%= company.ic_dph.presence || "—" %></p>
                    <p><strong>Address:</strong> <%= company.street %>, <%= company.city %>, <%= company.postal_code %>, <%= company.country %></p>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-base-content/70">You have not added any companies yet.</p>
          <% end %>
        </div>
      </div>
    </div>
  <% else %>
    <div class="card border border-base-content/10 bg-base-100 shadow-xl">
      <div class="card-body text-center space-y-4">
        <h1 class="text-3xl font-bold">Welcome</h1>
        <p class="text-base-content/70">
          Please log in or create an account to continue.
        </p>

        <div class="flex justify-center gap-3">
          <%= link_to "Log in", login_path, class: "btn btn-primary" %>
          <%= link_to "Register", sign_up_path, class: "btn btn-outline" %>
        </div>
      </div>
    </div>
  <% end %>
</div>

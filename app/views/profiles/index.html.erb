<div class="mx-auto mt-5 w-full max-w-xl px-4 py-16">
  <% if logged_in? %>
    <div class="card border border-base-content/10 bg-base-100 shadow-xl">
      <div class="card-body space-y-6">
        <div class="space-y-4">
          <h1 class="text-center text-3xl font-bold">Profil</h1>

          <div class="rounded-box border border-base-content/10 bg-base-200/40 p-5">
            <div class="flex items-start justify-between gap-4">
              <div class="min-w-0">
                <h2 class="break-words text-2xl font-bold"><%= current_user.username %></h2>
              </div>

              <span class="badge badge-primary badge-lg shrink-0">Úroveň <%= current_user.level %></span>
            </div>

            <div class="mt-5 space-y-2">
              <div class="flex items-center justify-between gap-3 text-sm font-semibold">
                <span>Postup XP</span>
                <span><%= current_user.xp_in_current_level %> / <%= current_user.xp_for_next_level %> XP</span>
              </div>

              <progress class="progress progress-primary h-3 w-full" value="<%= current_user.xp_progress_percentage %>" max="100"></progress>
            </div>
          </div>

          <div class="flex justify-center gap-3">
            <%= link_to "Pridať firmu", new_company_path, class: "btn btn-primary" %>
            <%= button_to "Odhlásiť sa", logout_path, method: :delete, class: "btn btn-error" %>
          </div>
        </div>

        <div>
          <h2 class="text-xl font-bold mb-4">Tvoje firmy</h2>

          <% if current_user.companies.any? %>
            <div class="space-y-4">
              <% current_user.companies.each do |company| %>
                <% selected = current_company == company %>
                <div class="rounded-box relative border p-4 <%= selected ? "border-primary ring-2 ring-primary/40" : "border-base-content/10 hover:border-primary/60" %>">
                  <% unless selected %>
                    <%= link_to "",
                      select_company_path(company),
                      data: { turbo_method: :patch },
                      class: "absolute inset-0 rounded-box",
                      aria: { label: "Prepnúť na firmu #{company.name}" } %>
                  <% end %>

                  <div class="flex items-start justify-between gap-4">
                    <div class="min-w-0">
                      <h3 class="break-words text-lg font-semibold"><%= company.name %></h3>
                      <% if selected %>
                        <span class="badge badge-primary mt-2">Vybraná</span>
                      <% end %>
                    </div>

                    <%= button_to "Vymazať",
                      company_path(company),
                      method: :delete,
                      class: "btn btn-error btn-sm",
                      form: { data: { turbo_confirm: "Vymazať firmu #{company.name}?" } } %>
                  </div>

                  <div class="mt-2 space-y-1 text-sm text-base-content/70">
                    <p><strong>IČO:</strong> <%= company.ico %></p>
                    <p><strong>DIČ:</strong> <%= company.dic.presence || "—" %></p>
                    <p><strong>IČ DPH:</strong> <%= company.ic_dph.presence || "—" %></p>
                    <p><strong>Adresa:</strong> <%= company.street %>, <%= company.city %>, <%= company.postal_code %>, <%= company.country %></p>
                  </div>

                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-base-content/70">Zatiaľ si nepridal žiadne firmy.</p>
          <% end %>
        </div>
      </div>
    </div>
  <% else %>
    <div class="card border border-base-content/10 bg-base-100 shadow-xl">
      <div class="card-body text-center space-y-4">
        <h1 class="text-3xl font-bold">Vitaj</h1>
        <p class="text-base-content/70">
          Prihlás sa alebo si vytvor účet, aby si mohol pokračovať.
        </p>

        <div class="flex justify-center gap-3">
          <%= link_to "Prihlásiť sa", login_path, class: "btn btn-primary" %>
          <%= link_to "Registrovať sa", sign_up_path, class: "btn btn-outline" %>
        </div>
      </div>
    </div>
  <% end %>
</div>

<div class="flex flex-col items-center gap-4">
  <div class="w-full max-w-3xl rounded-box border-3 border-base-content/10 bg-base-100/30 p-4">
    <div class="grid grid-cols-2 items-center">
      <div class="justify-self-start">
        <%= link_to "Späť", clients_path, class: "btn btn-outline btn-sm" %>
      </div>
      <div class="justify-self-end">
        <%= link_to "Upraviť", edit_client_path(@client), class: "btn btn-primary btn-sm" %>
      </div>
    </div>
  </div>

  <div class="w-full max-w-3xl rounded-box border-3 border-base-content/10 bg-base-100/30 p-6">
    <dl class="grid grid-cols-2 gap-x-8 gap-y-3">
      <dt class="font-semibold text-base-content/80">Typ klienta</dt>
      <dd><%= @client.person? ? "Súkromná osoba" : "Firma" %></dd>

      <dt class="font-semibold text-base-content/80"><%= @client.person? ? "Meno a priezvisko" : "Názov firmy" %></dt>
      <dd><%= @client.display_name %></dd>

      <% if @client.company? %>
        <dt class="font-semibold text-base-content/80">IČO</dt>
        <dd><%= @client.ico.presence || "—" %></dd>

        <dt class="font-semibold text-base-content/80">DIČ</dt>
        <dd><%= @client.dic.presence || "—" %></dd>

        <dt class="font-semibold text-base-content/80">IČ DPH</dt>
        <dd><%= @client.ic_dph.presence || "—" %></dd>
      <% end %>

      <dt class="font-semibold text-base-content/80">Ulica</dt>
      <dd><%= @client.street.presence || "—" %></dd>

      <dt class="font-semibold text-base-content/80">Mesto</dt>
      <dd><%= @client.city.presence || "—" %></dd>

      <dt class="font-semibold text-base-content/80">PSČ</dt>
      <dd><%= @client.postal_code.presence || "—" %></dd>

      <dt class="font-semibold text-base-content/80">Krajina</dt>
      <dd><%= @client.country.presence || "—" %></dd>

      <dt class="font-semibold text-base-content/80">Adresa</dt>
      <dd><%= simple_format(@client.display_address.presence || "—") %></dd>

      <dt class="font-semibold text-base-content/80">E-mail</dt>
      <dd>
        <% if @client.email.present? %>
          <%= mail_to @client.email, @client.email, class: "link link-primary" %>
        <% else %>
          —
        <% end %>
      </dd>

      <dt class="font-semibold text-base-content/80">Webová stránka</dt>
      <dd>
        <% if @client.website.present? %>
          <%= link_to @client.website, @client.website, class: "link link-primary", target: "_blank", rel: "noopener" %>
        <% else %>
          —
        <% end %>
      </dd>

      <dt class="font-semibold text-base-content/80">Telefónne číslo</dt>
      <dd><%= @client.phone.presence || "—" %></dd>

      <dt class="font-semibold text-base-content/80">Poznámka</dt>
      <dd><%= simple_format(@client.note.presence || "—") %></dd>
    </dl>
  </div>

  <div class="w-full max-w-3xl rounded-box border-3 border-base-content/10 bg-base-100/30 p-4">
    <div class="flex justify-end">
      <%= button_to "Vymazať", client_path(@client), method: :delete,
            data: { turbo_confirm: "Naozaj chceš vymazať tohto klienta?" },
            class: "btn btn-error btn-outline btn-sm" %>
    </div>
  </div>
</div>

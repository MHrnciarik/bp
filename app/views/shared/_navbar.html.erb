<nav class="navbar bg-neutral text-neutral-content shadow-lg transition-shadow duration-500 ease-in-out hover:shadow-2xl">
  <div class="navbar-start"></div>

  <div class="navbar-center gap-6">
    <%= link_to "Faktúry", invoices_path, class: "btn btn-ghost text-xl" %>
    <%= link_to "Výdavky", expenses_path, class: "btn btn-ghost text-xl" %>
    <%= link_to "Profil", profiles_path, class: "btn btn-ghost text-xl" %>
  </div>
  <div class="navbar-end px-4">
    <% if logged_in? && current_company.present? %>
      <%= link_to leaderboard_path, class: "btn btn-ghost btn-circle mr-2", aria: { label: "Rebríček používateľov" }, title: "Rebríček používateľov" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />
        </svg>
      <% end %>
      <%= link_to daily_missions_path, class: "btn btn-ghost btn-circle mr-4 relative", aria: { label: "Denné misie" }, title: "Denné misie" do %>
        <% if missions_ready_to_claim? %>
          <span
            class="absolute right-1.5 top-1.5 h-3 w-3 rounded-full bg-error shadow-sm shadow-error/70"
            data-testid="missions-notification-dot"
          ></span>
        <% end %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4"/><path d="M12 2v4"/><path d="M16 2v4"/><rect width="16" height="18" x="4" y="4" rx="2"/><path d="M8 10h6"/><path d="M8 14h8"/><path d="M8 18h5"/></svg>
      <% end %>
      <%= link_to profiles_path, class: "badge badge-primary badge-lg max-w-56 truncate" do %>
        <%= current_company.name %>
      <% end %>
    <% end %>
  </div>
</nav>

<%= form_with model: @invoice, class: "bg-charcoal-light rounded-xl border border-charcoal-lighter shadow-lg p-8 space-y-5" do |f| %>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
    <div>
      <%= f.label :issued_on, class: "form-label" %>
      <%= f.date_field :issued_on, class: "form-input" %>
    </div>
    <div>
      <%= f.label :due_on, class: "form-label" %>
      <%= f.date_field :due_on, class: "form-input" %>
    </div>
    <div>
      <%= f.label :status, class: "form-label" %>
      <%= f.select :status, Invoice::STATUSES.map { |s| [s.capitalize, s] },
            {},
            class: "appearance-none form-input cursor-pointer" %>
    </div>
    <div>
      <%= f.label :currency, class: "form-label" %>
      <%= f.select :currency, Invoice::CURRENCIES,
        {},
        class: "form-input" %>
    </div>
    <div>
      <%= f.label :amount, class: "form-label" %>
      <%= f.number_field :amount, step: 1, class: "form-input" %>
    </div>
    <div>
      <%= f.label :number, class: "form-label" %>
      <%= f.text_field :number, class: "form-input" %>
    </div>
    <div>
      <%= f.label :client_name, class: "form-label" %>
      <%= f.text_field :client_name, class: "form-input" %>
    </div>
    <div>
      <%= f.label :client_address, class: "form-label" %>
      <%= f.text_field :client_address, class: "form-input" %>
    </div>
  </div>

  <div>
    <%= f.label :note, class: "form-label" %>
    <%= f.text_area :note, rows: 4, class: "form-input" %>
  </div>

  <div class="pt-2">
    <%= f.submit class: "submit-button" %>
  </div>
<% end %>
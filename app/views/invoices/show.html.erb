<div class="flex flex-col items-center gap-4">
  <div class="w-full max-w-3xl rounded-box border-3 border-base-content/10 bg-base-100/30 p-4">
    <div class="grid grid-cols-2 items-center">
      <div class="justify-self-start">
        <%= link_to "Späť", invoices_path, class: "btn btn-outline btn-sm" %>
      </div>
      <div class="justify-self-end">
        <%= link_to "Upraviť", edit_invoice_path(@invoice), class: "btn btn-primary btn-sm" %>
      </div>
    </div>
  </div>

  <div class="w-full max-w-3xl rounded-box border-3 border-base-content/10 bg-base-100/30 p-6">
    <dl class="grid grid-cols-2 gap-x-8 gap-y-3">
      <dt class="font-semibold text-base-content/80">Číslo faktúry</dt>
      <dd><%= @invoice.display_number %></dd>

      <dt class="font-semibold text-base-content/80">Dátum vystavenia</dt>
      <dd><%= l(@invoice.issued_on, format: :long) %></dd>

      <dt class="font-semibold text-base-content/80">Dátum splatnosti</dt>
      <dd><%= l(@invoice.due_on, format: :long) %></dd>

      <dt class="font-semibold text-base-content/80">Klient</dt>
      <dd><%= @invoice.client_name.presence || "—" %></dd>

      <dt class="font-semibold text-base-content/80">Adresa klienta</dt>
      <dd><%= @invoice.client_address.presence || "—" %></dd>

      <dt class="font-semibold text-base-content/80">Stav</dt>
      <dd><%= invoice_status_label(@invoice.status) %></dd>

      <dt class="font-semibold text-base-content/80">Mena</dt>
      <dd><%= @invoice.currency %></dd>

      <dt class="font-semibold text-base-content/80">DPH</dt>
      <dd><%= number_with_precision(@invoice.tax_rate, precision: 2) %>%</dd>
    </dl>
  </div>

  <div class="w-full max-w-3xl rounded-box border-3 border-base-content/10 bg-base-100/30 p-6">
    <div class="flex items-center justify-between gap-3">
      <h2 class="text-lg font-bold">Položky</h2>
    </div>

    <div class="mt-4 overflow-x-auto">
      <table class="table w-full">
        <thead>
          <tr class="text-base-content/70">
            <th>Názov</th>
            <th class="text-right">Množstvo</th>
            <th class="text-right">Cena</th>
            <th class="text-right">Spolu za položku</th>
          </tr>
        </thead>
        <tbody>
          <% @invoice.invoice_items.each do |item| %>
            <tr>
              <td><%= item.name %></td>
              <td class="text-right"><%= item.quantity %></td>
              <td class="text-right"><%= number_to_currency(item.unit_price, unit: @invoice.currency, format: "%n %u") %></td>
              <td class="text-right font-semibold"><%= number_to_currency(item.total_price, unit: @invoice.currency, format: "%n %u") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <% if @invoice.note.present? %>
    <div class="w-full max-w-3xl rounded-box border-3 border-base-content/10 bg-base-100/30 p-6">
      <h2 class="mb-2 text-lg font-bold">Poznámka</h2>
      <p class="text-base-content/90"><%= @invoice.note %></p>
    </div>
  <% end %>

  <div class="w-full max-w-3xl rounded-box border-3 border-base-content/10 bg-base-100/30 p-4">
    <div class="grid grid-cols-2 items-center">
      <div>
        <h2 class="text-lg font-bold mx-2">
          <span class="block text-sm font-normal text-base-content/60">
            Medzisúčet: <%= number_to_currency(@invoice.subtotal_amount, unit: @invoice.currency, format: "%n %u") %>
          </span>
          Celkom:
          <span class="font-semibold text-base-content">
            <%= number_to_currency(@invoice.amount, unit: @invoice.currency, format: "%n %u") %>
          </span>
        </h2>
      </div>
      <div class="justify-self-end">
        <%= button_to "Vymazať", invoice_path(@invoice), method: :delete,
              data: { turbo_confirm: "Naozaj chceš vymazať túto faktúru?" },
              class: "btn btn-error btn-outline btn-sm" %>
      </div>
    </div>
  </div>
</div>

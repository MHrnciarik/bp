<div class="flex flex-col items-center">
  <div class="w-full max-w-5xl">
    <details class="collapse collapse-arrow border-3 border-base-content/10 my-4">
      <summary class="collapse-title font-bold">Filtre</summary>
      <div class="collapse-content text-sm">
        <%= form_with url: invoices_path, method: :get, class: "grid grid-cols-6 gap-4 w-full" do |form| %>
        <div class="flex">
          <div class="mt-auto">
            <%= form.submit "Filtrovať", class: "btn btn-soft btn-primary" %>
            <%= link_to "Vymazať", invoices_path, class: "btn btn-soft btn-error" %>
          </div>
        </div>
        <div>
          <div>
            <%= form.label :issued_start_date, "Od", class: "label" %>
            <%= form.date_field :issued_start_date, value: params[:issued_start_date], class: "input date w-full" %>
          </div>
          <div>
            <%= form.label :issued_end_date, "Do", class: "label" %>
            <%= form.date_field :issued_end_date, value: params[:issued_end_date], class: "input date w-full" %>
          </div>
        </div>

        <div>
          <div>
            <%= form.label :due_start_date, "Od", class: "label" %>
            <%= form.date_field :due_start_date, value: params[:due_start_date], class: "input date w-full" %>
          </div>
          <div>
            <%= form.label :due_end_date, "Do", class: "label" %>
            <%= form.date_field :due_end_date, value: params[:due_end_date], class: "input date w-full" %>
          </div>
        </div>
        
        <div>
           <%= form.select :client_name,
                  options_for_select(@clients, params[:client_name]),
                  { include_blank: "Všetci klienti" },
                  { class: "select w-full mt-5" } %>
        </div>


          <div>
            <%= form.select :status,
                  invoice_status_options(params[:status]),
                  { include_blank: "Všetky stavy" },
                  { class: "select w-full mt-5" } %>    
          </div>

          <div>
             <%= form.label :min_amount, "Min. suma", class: "label" %>
            <%= form.number_field :min_amount,
                  min: 0,
                  max: 1000000,
                  step: 1,
                  value: params[:min_amount] || 0,
                  class: "input input-bordered w-full" %>

            <%= form.label :max_amount, "Max. suma", class: "label" %>
            <%= form.number_field :max_amount,
                  min: 0,
                  max: 1000000,
                  step: 1,
                  value: params[:max_amount] || 1000000,
                  class: "input input-bordered w-full" %>
          </div>

        <% end %>
      </div>
    </details>

    <% if @invoices.any? %>
      <div class="flex justify-center my-4">
        <div class="overflow-x-auto rounded-box border-3 border-base-content/10 w-full">
          <table class="table-lg table-fixed w-full">
            <thead>
              <tr class="border-b-2 border-base-content/10 text-left">
                <th>Faktúra č.</th>
                <th>Vystavená</th>
                <th>Splatná</th>
                <th>Klient</th>
                <th>Stav</th>
                <th class="text-right">Suma</th>
              </tr>
            </thead>
            <tbody>
              <% @invoices.each do |invoice| %>
                <tr class="hover:bg-base-300 border-b border-base-content/5 cursor-pointer" onclick="window.location='<%= invoice_path(invoice) %>'">
                  <td><%= invoice.number.presence || "—" %></td>
                  <td><%= invoice.issued_on ? l(invoice.issued_on, format: :short) : "—" %></td>
                  <td><%= invoice.due_on ? l(invoice.due_on, format: :short) : "—" %></td>
                  <td><%= invoice.client_name.presence || "—" %></td>
                  <td><%= invoice_status_label(invoice.status) %></td>
                  <td class="text-right"><%= number_to_currency(invoice.amount, unit: invoice.currency, format: "%n %u") %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% else %>
      <p class="my-4">Nenašli sa žiadne faktúry.</p>
    <% end %>
  </div>
</div>

<div class="fab m-4">
  <%= link_to "+", new_invoice_path, class: "btn btn-lg btn-circle btn-primary" %>
</div>

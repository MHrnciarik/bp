<div>
  <h1>Invoices</h1>
  <%= link_to "+ New Invoice", new_invoice_path %>
</div>

<table>
  <thead>
    <tr>
      <th>Issued</th>
      <th>Client</th>
      <th>Amount</th>
      <th>Status</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @invoices.each do |inv| %>
      <tr>
        <td><%= inv.issued_on %></td>
        <td><%= inv.client_name %></td>
        <td><%= "#{inv.currency} #{'%.2f' % inv.amount}" %></td>
        <td><%= inv.status %></td>
        <td>
          <%= link_to "Show", invoice_path(inv) %>
          <%= link_to "Edit", edit_invoice_path(inv) %>
          <%= link_to "Delete", invoice_path(inv), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
<%= form_with model: company, class: "space-y-4" do |f| %>
  <div>
    <%= f.label :name, "Názov firmy", class: "label font-semibold" %>
    <%= f.text_field :name, class: "input input-bordered w-full" %>
  </div>

  <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
    <div>
      <%= f.label :ico, "IČO", class: "label font-semibold" %>
      <%= f.text_field :ico,
        class: "input input-bordered w-full",
        inputmode: "numeric",
        maxlength: 8,
        pattern: "\\d{8}",
        title: "Zadaj presne 8 číslic" %>
    </div>

    <div>
      <%= f.label :dic, "DIČ", class: "label font-semibold" %>
      <%= f.text_field :dic,
        class: "input input-bordered w-full",
        inputmode: "numeric",
        maxlength: 10,
        pattern: "\\d{8,10}",
        title: "Zadaj 8 až 10 číslic" %>
    </div>
  </div>

  <div>
    <%= f.label :ic_dph, "IČ DPH", class: "label font-semibold" %>
    <%= f.text_field :ic_dph,
      class: "input input-bordered w-full",
      maxlength: 12,
      pattern: "(SK|CZ)\\d{10}",
      title: "Zadaj SK alebo CZ a potom 10 číslic" %>
  </div>

  <div>
    <%= f.label :street, "Ulica", class: "label font-semibold" %>
    <%= f.text_field :street, class: "input input-bordered w-full" %>
  </div>

  <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
    <div>
      <%= f.label :city, "Mesto", class: "label font-semibold" %>
      <%= f.text_field :city, class: "input input-bordered w-full" %>
    </div>

    <div>
      <%= f.label :postal_code, "PSČ", class: "label font-semibold" %>
      <%= f.text_field :postal_code,
        class: "input input-bordered w-full",
        inputmode: "numeric",
        maxlength: 5,
        pattern: "\\d{5}",
        title: "Zadaj presne 5 číslic" %>
    </div>

    <div>
      <%= f.label :country, "Krajina", class: "label font-semibold" %>
      <%= f.text_field :country, class: "input input-bordered w-full" %>
    </div>
  </div>

  <div class="flex justify-end gap-3">
    <%= link_to "Späť", profiles_path, class: "btn btn-ghost" %>
    <%= f.submit "Uložiť firmu", class: "btn btn-primary" %>
  </div>
<% end %>

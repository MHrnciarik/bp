<%= form_with model: @expense,
      class: "w-full max-w-4xl mx-auto rounded-box border-3 border-base-content/10 bg-base-100/30 p-6 space-y-6 mb-4",
      data: { controller: "expense-items party-switch" } do |f| %>
  <% if @expense.errors.any? %>
    <div class="rounded-box border border-error/30 bg-error/10 p-4">
      <h2 class="font-semibold text-error">Oprav zvýraznené chyby.</h2>
      <ul class="mt-2 list-disc pl-5 text-sm">
        <% @expense.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <fieldset class="fieldset">
    <legend class="fieldset-legend text-2xl font-bold mb-2">Detaily výdavku</legend>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <div>
        <%= f.label :date, "Dátum", class: "label font-semibold text-lg" %>
        <%= f.date_field :date, class: "input input-bordered w-full" %>
      </div>

      <div>
        <%= f.label :currency, "Mena", class: "label font-semibold text-lg" %>
        <%= f.select :currency,
              options_for_select(Expense::CURRENCIES, @expense.currency),
              {},
              class: "select select-bordered w-full",
              data: { expense_items_target: "currencySelect", action: "change->expense-items#updateCurrency" } %>
      </div>

      <% vendor_mode = @expense.vendor_entry_mode.presence || (@expense.vendor_id.present? ? "saved" : "manual") %>
      <div class="md:col-span-2">
        <span class="label font-semibold text-lg">Dodávateľ / predajca</span>
        <div class="flex flex-wrap gap-3">
          <label class="btn btn-sm <%= vendor_mode == "saved" ? "btn-primary" : "btn-soft" %>"
                 data-party-switch-target="option"
                 data-party-switch-mode-value="saved">
            <%= f.radio_button :vendor_entry_mode,
                  "saved",
                  checked: vendor_mode == "saved",
                  class: "hidden",
                  data: { party_switch_target: "mode", action: "change->party-switch#update" } %>
            Uložený predajca
          </label>
          <label class="btn btn-sm <%= vendor_mode == "manual" ? "btn-primary" : "btn-soft" %>"
                 data-party-switch-target="option"
                 data-party-switch-mode-value="manual">
            <%= f.radio_button :vendor_entry_mode,
                  "manual",
                  checked: vendor_mode == "manual",
                  class: "hidden",
                  data: { party_switch_target: "mode", action: "change->party-switch#update" } %>
            Manuálne
          </label>
        </div>
      </div>

      <div class="<%= "hidden" unless vendor_mode == "saved" %>" data-party-switch-target="saved">
        <%= f.label :vendor_id, "Vyber predajcu", class: "label font-semibold text-lg" %>
        <%= f.collection_select :vendor_id,
              @saved_vendors,
              :id,
              :display_name,
              { prompt: "Vyber uloženého predajcu" },
              { class: "select select-bordered w-full" } %>
      </div>

      <% manual_vendor_kind = @expense.manual_vendor_kind %>
      <div class="md:col-span-2 space-y-5 <%= "hidden" unless vendor_mode == "manual" %>"
           data-party-switch-target="manual"
           data-controller="client-kind">
        <div>
          <span class="label font-semibold text-lg">Typ predajcu</span>
          <div class="flex flex-wrap gap-3">
            <label class="btn btn-sm <%= manual_vendor_kind == "company" ? "btn-primary" : "btn-soft" %>"
                   data-client-kind-target="option"
                   data-client-kind-mode-value="company">
              <%= f.radio_button :vendor_kind,
                    "company",
                    checked: manual_vendor_kind == "company",
                    class: "hidden",
                    data: { client_kind_target: "mode", action: "change->client-kind#update" } %>
              Firma
            </label>
            <label class="btn btn-sm <%= manual_vendor_kind == "person" ? "btn-primary" : "btn-soft" %>"
                   data-client-kind-target="option"
                   data-client-kind-mode-value="person">
              <%= f.radio_button :vendor_kind,
                    "person",
                    checked: manual_vendor_kind == "person",
                    class: "hidden",
                    data: { client_kind_target: "mode", action: "change->client-kind#update" } %>
              Súkromná osoba
            </label>
          </div>
        </div>

        <div class="space-y-4 <%= "hidden" unless manual_vendor_kind == "company" %>" data-client-kind-target="company">
          <div>
            <%= f.label :vendor, "Názov firmy", class: "label font-semibold text-lg" %>
            <%= f.text_field :vendor, class: "input input-bordered w-full" %>
          </div>

          <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
            <div>
              <%= f.label :vendor_ico, "IČO predajcu", class: "label font-semibold text-lg" %>
              <%= f.text_field :vendor_ico,
                class: "input input-bordered w-full",
                inputmode: "numeric",
                maxlength: 8,
                pattern: "\\d{8}",
                title: "Zadaj presne 8 číslic" %>
            </div>

            <div>
              <%= f.label :vendor_dic, "DIČ predajcu", class: "label font-semibold text-lg" %>
              <%= f.text_field :vendor_dic,
                class: "input input-bordered w-full",
                inputmode: "numeric",
                maxlength: 10,
                pattern: "\\d{8,10}",
                title: "Zadaj 8 až 10 číslic" %>
            </div>
          </div>

          <div>
            <%= f.label :vendor_ic_dph, "IČ DPH predajcu", class: "label font-semibold text-lg" %>
            <%= f.text_field :vendor_ic_dph,
              class: "input input-bordered w-full",
              maxlength: 12,
              pattern: "(SK|CZ)\\d{10}",
              title: "Zadaj SK alebo CZ a potom 10 číslic" %>
          </div>
        </div>

        <div class="grid grid-cols-1 gap-4 md:grid-cols-2 <%= "hidden" unless manual_vendor_kind == "person" %>" data-client-kind-target="person">
          <div>
            <%= f.label :vendor_first_name, "Meno", class: "label font-semibold text-lg" %>
            <%= f.text_field :vendor_first_name, class: "input input-bordered w-full" %>
          </div>

          <div>
            <%= f.label :vendor_last_name, "Priezvisko", class: "label font-semibold text-lg" %>
            <%= f.text_field :vendor_last_name, class: "input input-bordered w-full" %>
          </div>
        </div>

        <div>
          <%= f.label :vendor_street, "Ulica predajcu", class: "label font-semibold text-lg" %>
          <%= f.text_field :vendor_street, class: "input input-bordered w-full" %>
        </div>

        <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
          <div>
            <%= f.label :vendor_city, "Mesto predajcu", class: "label font-semibold text-lg" %>
            <%= f.text_field :vendor_city, class: "input input-bordered w-full" %>
          </div>

          <div>
            <%= f.label :vendor_postal_code, "PSČ predajcu", class: "label font-semibold text-lg" %>
            <%= f.text_field :vendor_postal_code,
              class: "input input-bordered w-full",
              inputmode: "numeric",
              maxlength: 5,
              pattern: "\\d{5}",
              title: "Zadaj presne 5 číslic" %>
          </div>

          <div>
            <%= f.label :vendor_country, "Krajina predajcu", class: "label font-semibold text-lg" %>
            <%= f.text_field :vendor_country, class: "input input-bordered w-full" %>
          </div>
        </div>
      </div>

      <div>
        <%= f.label :category, "Kategória", class: "label font-semibold text-lg" %>
        <%= f.select :category,
              expense_category_options(@expense.category),
              { prompt: "Vyber kategóriu" },
              { class: "select select-bordered w-full" } %>
      </div>

      <div>
        <%= f.label :payment_method, "Spôsob platby", class: "label font-semibold text-lg" %>
        <%= f.select :payment_method,
              payment_method_options(@expense.payment_method),
              { prompt: "Vyber spôsob platby" },
              { class: "select select-bordered w-full" } %>
      </div>

      <div class="md:col-span-2">
        <%= f.label :note, "Poznámka", class: "label font-semibold text-lg" %>
        <%= f.text_area :note, rows: 3, placeholder: "Voliteľné poznámky...", class: "textarea textarea-bordered w-full" %>
      </div>
    </div>
  </fieldset>

  <fieldset class="fieldset">
    <div class="flex items-center justify-between gap-3">
      <legend class="fieldset-legend text-2xl font-bold mb-2">Položky</legend>
      <button type="button" class="btn btn-sm btn-soft btn-primary" data-action="expense-items#addRow">Pridať položku</button>
    </div>

    <div class="overflow-x-auto rounded-box border border-base-content/10 bg-base-100/40 p-3">
      <table class="table w-full">
        <thead>
          <tr class="text-base-content/70">
            <th>Názov</th>
            <th>Množstvo</th>
            <th>Cena</th>
            <th>DPH (%)</th>
            <th class="px-0 text-right">Spolu s DPH</th>
            <th></th>
          </tr>
        </thead>
        <tbody data-expense-items-target="items">
          <%= f.fields_for :expense_items do |item_fields| %>
            <%= render "expense_item_fields", f: item_fields %>
          <% end %>
        </tbody>
      </table>
    </div>

    <template data-expense-items-target="template">
      <%= f.fields_for :expense_items, ExpenseItem.new(quantity: 1, tax_rate: 23), child_index: "NEW_RECORD" do |item_fields| %>
        <%= render "expense_item_fields", f: item_fields %>
      <% end %>
    </template>
  </fieldset>

  <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
    <div class="rounded-box border border-base-content/10 bg-base-100/40 px-4 py-3">
      <p class="text-sm text-base-content/60">
        Medzisúčet:
        <span data-expense-items-target="subtotal">0.00</span>
        <span data-expense-items-target="currencyLabel"><%= @expense.currency.presence || Expense::CURRENCIES.first %></span>
      </p>
      <p class="text-sm uppercase tracking-wide text-base-content/60">Výdavok spolu</p>
      <p class="text-2xl font-bold">
        <span data-expense-items-target="total">0.00</span>
        <span><%= @expense.currency.presence || Expense::CURRENCIES.first %></span>
      </p>
    </div>

    <div class="flex items-center justify-end gap-3">
      <%= link_to "Zrušiť", @expense.persisted? ? expense_path(@expense) : expenses_path, class: "btn btn-ghost btn-error" %>
      <%= f.submit(@expense.persisted? ? "Uložiť výdavok" : "Vytvoriť výdavok", class: "btn btn-primary") %>
    </div>
  </div>
<% end %>

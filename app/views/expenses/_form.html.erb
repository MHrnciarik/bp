<%= form_with model: @expense,
      class: "w-full max-w-4xl mx-auto rounded-box border-3 border-base-content/10 bg-base-100/30 p-6 space-y-6 my-4",
      data: { controller: "expense-items" } do |f| %>
  <% if @expense.errors.any? %>
    <div class="rounded-box border border-error/30 bg-error/10 p-4">
      <h2 class="font-semibold text-error">Please fix the highlighted issues.</h2>
      <ul class="mt-2 list-disc pl-5 text-sm">
        <% @expense.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <fieldset class="fieldset">
    <legend class="fieldset-legend text-2xl font-bold mb-2">Expense Details</legend>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <div>
        <%= f.label :date, class: "label font-semibold text-lg" %>
        <%= f.date_field :date, class: "input input-bordered w-full" %>
      </div>

      <div>
        <%= f.label :currency, class: "label font-semibold text-lg" %>
        <%= f.select :currency,
              options_for_select(Expense::CURRENCIES, @expense.currency),
              {},
              class: "select select-bordered w-full",
              data: { expense_items_target: "currencySelect", action: "change->expense-items#updateCurrency" } %>
      </div>

      <div>
        <%= f.label :vendor, "Vendor / Merchant", class: "label font-semibold text-lg" %>
        <%= f.text_field :vendor, class: "input input-bordered w-full" %>
      </div>

      <div>
        <%= f.label :category, class: "label font-semibold text-lg" %>
        <%= f.select :category,
              options_for_select(Expense::CATEGORIES, @expense.category),
              { prompt: "Select a category" },
              { class: "select select-bordered w-full" } %>
      </div>

      <div>
        <%= f.label :payment_method, class: "label font-semibold text-lg" %>
        <%= f.select :payment_method,
              options_for_select(Expense::PAYMENT_METHODS, @expense.payment_method),
              { prompt: "Select payment method" },
              { class: "select select-bordered w-full" } %>
      </div>

      <div>
        <%= f.label :tax_rate, "DPH (%)", class: "label font-semibold text-lg" %>
        <%= f.number_field :tax_rate,
              step: 0.01,
              min: 0,
              class: "input input-bordered w-full",
              data: { expense_items_target: "taxRate", action: "input->expense-items#updateTotals" } %>
      </div>

      <div class="md:col-span-2">
        <%= f.label :note, class: "label font-semibold text-lg" %>
        <%= f.text_area :note, rows: 3, placeholder: "Optional notes...", class: "textarea textarea-bordered w-full" %>
      </div>
    </div>
  </fieldset>

  <fieldset class="fieldset">
    <div class="flex items-center justify-between gap-3">
      <legend class="fieldset-legend text-2xl font-bold mb-2">Items</legend>
      <button type="button" class="btn btn-sm btn-soft btn-primary" data-action="expense-items#addRow">Add item</button>
    </div>

    <div class="overflow-x-auto rounded-box border border-base-content/10 bg-base-100/40 p-3">
      <table class="table w-full">
        <thead>
          <tr class="text-base-content/70">
            <th>Name</th>
            <th>Amount</th>
            <th>Price</th>
            <th class="px-0 text-right">Items total</th>
            <th></th>
          </tr>
        </thead>
        <tbody data-expense-items-target="items">
          <%= f.fields_for :expense_items do |item_fields| %>
            <%= render "expense_item_fields", f: item_fields %>
          <% end %>
        </tbody>
      </table>
    </div>

    <template data-expense-items-target="template">
      <%= f.fields_for :expense_items, ExpenseItem.new(quantity: 1), child_index: "NEW_RECORD" do |item_fields| %>
        <%= render "expense_item_fields", f: item_fields %>
      <% end %>
    </template>
  </fieldset>

  <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
    <div class="rounded-box border border-base-content/10 bg-base-100/40 px-4 py-3">
      <p class="text-sm text-base-content/60">
        Subtotal:
        <span data-expense-items-target="subtotal">0.00</span>
        <span data-expense-items-target="currencyLabel"><%= @expense.currency.presence || Expense::CURRENCIES.first %></span>
      </p>
      <p class="text-sm uppercase tracking-wide text-base-content/60">Expense total</p>
      <p class="text-2xl font-bold">
        <span data-expense-items-target="total">0.00</span>
        <span><%= @expense.currency.presence || Expense::CURRENCIES.first %></span>
      </p>
    </div>

    <div class="flex items-center justify-end gap-3">
      <%= link_to "Cancel", expenses_path, class: "btn btn-ghost btn-error" %>
      <%= f.submit class: "btn btn-primary" %>
    </div>
  </div>
<% end %>

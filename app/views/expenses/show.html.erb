<div class="flex flex-col items-center gap-4">
  <div class="w-full max-w-3xl rounded-box border-3 border-base-content/10 bg-base-100/30 p-4">
    <div class="grid grid-cols-2 items-center">
      <div class="justify-self-start">
        <%= link_to "Späť", expenses_path, class:"btn btn-outline btn-sm" %>
      </div>
      <div class="justify-self-end">
        <%= link_to "Upraviť", edit_expense_path(@expense), class:"btn btn-primary btn-sm" %>
      </div>
    </div>
  </div>

  <div class="w-full max-w-3xl rounded-box border-3 border-base-content/10 bg-base-100/30 p-6">
    <dl class="grid grid-cols-2 gap-x-8 gap-y-3">
      <dt class="font-semibold text-base-content/80">Dátum</dt>
      <dd><%= l(@expense.date, format: :long) %></dd>

      <dt class="font-semibold text-base-content/80">Suma</dt>
      <dd><%= number_to_currency(@expense.amount, unit: @expense.currency, format: "%n %u") %></dd>

      <dt class="font-semibold text-base-content/80">Kategória</dt>
      <dd><%= expense_category_label(@expense.category) %></dd>

      <dt class="font-semibold text-base-content/80">Spôsob platby</dt>
      <dd><%= payment_method_label(@expense.payment_method) %></dd>

      <dt class="font-semibold text-base-content/80">Dodávateľ / predajca</dt>
      <dd>
        <% if @expense.vendor_record.present? %>
          <%= link_to @expense.vendor, vendor_path(@expense.vendor_record), class: "link link-primary" %>
        <% else %>
          <%= @expense.vendor.presence || "—" %>
        <% end %>
      </dd>

      <dt class="font-semibold text-base-content/80">Mena</dt>
      <dd><%= @expense.currency %></dd>
    </dl>
  </div>

  <div class="w-full max-w-3xl rounded-box border-3 border-base-content/10 bg-base-100/30 p-6">
    <div class="flex items-center justify-between gap-3">
      <h2 class="text-lg font-bold">Položky</h2>
    </div>

    <div class="mt-4 overflow-x-auto">
      <table class="table w-full">
        <thead>
          <tr class="text-base-content/70">
            <th>Názov</th>
            <th class="text-right">Množstvo</th>
            <th class="text-right">Cena bez DPH</th>
            <th class="text-right">DPH</th>
            <th class="text-right">Spolu s DPH</th>
          </tr>
        </thead>
        <tbody>
          <% @expense.expense_items.each do |item| %>
            <tr>
              <td><%= item.name %></td>
              <td class="text-right"><%= item.quantity %></td>
              <td class="text-right"><%= number_to_currency(item.unit_price, unit: @expense.currency, format: "%n %u") %></td>
              <td class="text-right"><%= number_with_precision(item.tax_rate, precision: 2) %>%</td>
              <td class="text-right font-semibold"><%= number_to_currency(item.total_price, unit: @expense.currency, format: "%n %u") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <% if @expense.note.present? %>
    <div class="w-full max-w-3xl rounded-box border-3 border-base-content/10 bg-base-100/30 p-6">
      <h2 class="mb-2 text-lg font-bold">Poznámka</h2>
      <p class="text-base-content/90"><%= @expense.note %></p>
    </div>
  <% end %>

  <div class="w-full max-w-3xl rounded-box border-3 border-base-content/10 bg-base-100/30 p-4">
    <div class="grid grid-cols-2 items-center">
      <div>
        <h2 class="text-lg font-bold mx-2">
          <span class="block text-sm font-normal text-base-content/60">
            Medzisúčet: <%= number_to_currency(@expense.subtotal_amount, unit: @expense.currency, format: "%n %u") %>
          </span>
          Celkom:
          <span class="font-semibold text-base-content">
            <%= number_to_currency(@expense.amount, unit: @expense.currency, format: "%n %u") %>
          </span>
        </h2>
      </div>
      <div class="justify-self-end">
        <%= button_to "Vymazať", expense_path(@expense), method: :delete,
              data: { turbo_confirm: "Naozaj chceš vymazať tento výdavok?" },
              class:"btn btn-error btn-outline btn-sm" %>
      </div>
    </div>
  </div>
</div>
